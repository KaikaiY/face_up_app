<section class="practice-layout">
  <article class="practice-panel">
    <%= link_to "問題へ戻る", problem_path(@problem), class: "back-link" %>
    <p class="unit-label"><%= @problem.unit %></p>
    <h1><%= @problem.title %></h1>
    <div class="question-box">
      <%= simple_format(@problem.question) %>
    </div>

    <div class="answer-result <%= @result %>">
      <span class="status-pill <%= @result %>"><%= Attempt::RESULTS.fetch(@result) %></span>
      <dl>
        <div>
          <dt>あなたの答え</dt>
          <dd><%= @submitted_answer %></dd>
        </div>
        <div>
          <dt>答え</dt>
          <dd><%= @problem.answer %></dd>
        </div>
      </dl>
    </div>

    <div class="summary-card">
      <h2>答えを見る前の考え</h2>
      <p><%= @thought_process %></p>
    </div>
  </article>

  <aside class="answer-panel">
    <h2>結果を見て、どう感じた？</h2>
    <p class="empty-text">正解・不正解そのものより、今どこが見えているかを残しましょう。</p>

    <%= form_with model: @attempt, url: attempts_path, class: "reflection-form", data: { turbo: false } do |form| %>
      <%= form.hidden_field :problem_id, value: @problem.id %>
      <%= form.hidden_field :submitted_answer, value: @submitted_answer %>
      <%= form.hidden_field :thought_process, value: @thought_process %>

      <div class="field-group">
        <%= form.label :reflection_reason, "今の気持ちに近いもの" %>
        <div class="choice-grid">
          <% Attempt.reflection_reasons_for(@result).each do |key, label| %>
            <label class="choice-option">
              <%= form.radio_button :reflection_reason, key %>
              <span><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="field-group">
        <%= form.label :next_focus, "次に気をつけること" %>
        <div class="choice-grid">
          <% Attempt::NEXT_FOCUS_OPTIONS.each do |key, label| %>
            <label class="choice-option">
              <%= form.radio_button :next_focus, key %>
              <span><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="field-group">
        <%= form.label :confidence, "自信メーター" %>
        <%= form.range_field :confidence, min: 1, max: 5 %>
      </div>

      <div class="field-group">
        <%= form.label :note, "メモ" %>
        <%= form.text_area :note, rows: 4, placeholder: "結果を見て思ったこと、次に気をつけたいこと" %>
      </div>

      <%= form.submit "振り返りを記録する", class: "button primary-button" %>
    <% end %>
  </aside>
</section>
